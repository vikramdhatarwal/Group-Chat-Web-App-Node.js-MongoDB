<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create a new chat</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <main class="page-shell">
        <section class="hero">
            <div>
                <h1>New Chat</h1>
                <p class="subtitle">Send a quick message</p>
            </div>
            <!-- <div class="hero-badge">Create</div> -->
        </section>

        <section class="form-shell">
            <form action="/chats" method="POST" class="chat-form">
                <label class="field">
                    <span class="label-text">From</span>
                    <input type="text" name="from" placeholder="Your name" required>
                </label>

                <label class="field">
                    <span class="label-text">To</span>
                    <input type="text" name="to" placeholder="Recipient" required>
                </label>

                <label class="field">
                    <span class="label-text">Message</span>
                    <textarea name="message" rows="5" placeholder="Type a message" required></textarea>
                </label>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Send Message</button>
                    <a href="/chats" class="btn-secondary">Cancel</a>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
